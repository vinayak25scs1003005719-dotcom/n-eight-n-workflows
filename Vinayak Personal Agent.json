        1760
      ]
    },
    {
      "parameters": {
        "jsCode": "const count = items[0].json.count;\nconst emails = items[0].json.emails;\n\nreturn [{\n  json: {\n    payload: JSON.stringify({\n      model: \"mistralai/mistral-large-3-675b-instruct-2512\",\n      messages: [\n        {\n          role: \"system\",\n          content: \"You are Vinayak's personal assistant. Summarize his daily emails professionally. Group into: Client emails, Urgent/Important, Promotional/Spam. Flag client requests or deadlines. Keep the total summary under 1500 characters. Use clear headings. No emojis. KEEP IT PROFESSIONAL.\"\n        },\n        {\n          role: \"user\",\n          content: \"Here are \" + count + \" unread emails: \" + emails\n        }\n      ],\n      temperature: 0.15,\n      top_p: 1,\n      max_tokens: 1024,\n      frequency_penalty: 0,\n      presence_penalty: 0,\n      stream: false\n    })\n  }\n}];"
      },
