      "parameters": {
        "jsCode": "const items_list = items.map(item => ({\n  from: item.json.from,\n  subject: item.json.subject,\n  snippet: item.json.snippet,\n  date: item.json.date\n}));\n\nreturn [{ json: { emails: JSON.stringify(items_list, null, 2), count: items_list.length } }];"
      },
      "id": "e154524a-780c-4a18-bf00-59403dadc76c",
