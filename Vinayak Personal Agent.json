    {
      "parameters": {
        "jsCode": "const content = items[0];\nlet summaryText = '';\n\ntry {\n  if (content.json.choices && content.json.choices[0]) {\n    summaryText = content.json.choices[0].message.content;\n  } else if (content.json.message && content.json.message.content) {\n    summaryText = content.json.message.content;\n  } else if (content.json.text) {\n    summaryText = content.json.text;\n  } else {\n    summaryText = JSON.stringify(content.json);\n  }\n} catch(e) {\n  summaryText = 'Could not parse AI summary: ' + e.message;\n}\n\nreturn [{ json: { summaryText } }];"
      },
      "id": "37331f79-d412-4dcf-bad9-ff5e4e305aa7",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5168,
        1760
      ]
    },
    {
      "parameters": {
        "jsCode": "const text = items[0].json.summaryText;\nconst chunks = [];\nlet current = '';\n\nconst lines = text.split('\\n');\nfor (const line of lines) {\n  if ((current + '\\n' + line).length > 1900) {\n    chunks.push(current);\n    current = line;\n  } else {\n    current = current ? current + '\\n' + line : line;\n  }\n}\nif (current) chunks.push(current);\n\nreturn chunks.map((chunk, i) => ({\n  json: {\n    content: i === 0\n      ? '**Good morning Vinayak!**\\n\\n**Daily Email Summary**\\n\\n' + chunk\n      : chunk\n  }\n}));"
      },
