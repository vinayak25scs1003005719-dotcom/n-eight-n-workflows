        "jsCode": "const allRows = $input.all();\n\nconst staticData = $getWorkflowStaticData('global');\nconst processedIds = staticData.processedIds || [];\n\nconst newRows = [];\n\nfor (const row of allRows) {\n  const rowId = row.json['id'];\n  \n  if (!rowId || processedIds.includes(rowId)) {\n    continue;\n  }\n\n  newRows.push(row);\n  processedIds.push(rowId);\n}\n\nstaticData.processedIds = processedIds;\n\nif (newRows.length === 0) {\n  return [];\n}\n\nreturn newRows;"
