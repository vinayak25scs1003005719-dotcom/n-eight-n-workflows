28;font-weight:bold;\">{{ $json.full_name }}</p></td><td style=\"padding:14px 20px;border-bottom:1px solid #e8edf3;border-left:1px solid #e8edf3;\"><p style=\"margin:0;font-size:11px;color:#8a9bb0;text-transform:uppercase;letter-spacing:1px;\">Email</p><p style=\"margin:4px 0 0;font-size:15px;color:#0a1628;\">{{ $json.email }}</p></td></tr><tr><td style=\"padding:14px 20px;\" colspan=\"2\"><p style=\"margin:0;font-size:11px;color:#8a9bb0;text-transform:uppercase;letter-spacing:1px;\">Phone</p><p style=\"margin:4px 0 0;font-size:15px;color:#0a1628;\">{{ $json.phone_number }}</p></td></tr></table><p style=\"margin:0 0 6px;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#4a9eff;font-family:monospace;\">Qualification</p><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8edf3;border-radius:8px;overflow:hidden;margin-bottom:28px;\"><tr><td style=\"padding:14px 20px;border-bottom:1px solid #e8edf3;width:50%;\"><p style=\"margin:0;font-size:11px;color:#8a9bb0;text-transform:uppercase;letter-spacing:1px;\">Licensed Dentist (USA)?</p><p style=\"margin:4px 0 0;font-size:14px;color:#0a1628;\">{{ $json[\"are_you_a_licensed_dentist_in_the_usa?\"] }}</p></td><td style=\"padding:14px 20px;border-bottom:1px solid #e8edf3;border-left:1px solid #e8edf3;\"><p style=\"margin:0;font-size:11px;color:#8a9bb0;text-transform:uppercase;letter-spacing:1px;\">Years of Experience</p><p style=\"margin:4px 0 0;font-size:14px;color:#0a1628;\">{{ $json.years_of_experience }}</p></td></tr><tr><td style=\"padding:14px 20px;border-bottom:1px solid #e8edf3;\" colspan=\"2\"><p style=\"margin:0;font-size:11px;color:#8a9bb0;text-transform:uppercase;letter-spacing:1px;\">Best Describes You</p><p style=\"margin:4px 0 0;font-size:14px;color:#0a1628;\">{{ $json[\"which_best_describes_you?\"] }}</p></td></tr><tr><td style=\"padding:14px 20px;border-bottom:1px solid #e8edf3;\" colspan=\"2\"><p style=\"margin:0;font-size:11px;color:#8a9bb0;text-transform:upperca